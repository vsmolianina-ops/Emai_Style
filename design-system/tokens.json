{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "brand": { "name": "EMAi", "tagline": "caring by tech", "site": "emai.group" },
  "color": {
    "background": {
      "cream":      { "$value": "#F7F4EB", "$type": "color", "$description": "primary background" },
      "cream-soft": { "$value": "#FBF9F3", "$type": "color", "$description": "nested blocks" },
      "cream-deep": { "$value": "#EFE9D9", "$type": "color", "$description": "dividers, hover, placeholders" },
      "white":      { "$value": "#FFFFFF", "$type": "color", "$description": "cards, sections" },
      "surface-dark": { "$value": "#5E6472", "$type": "color", "$description": "dark sections only (titles, dividers) — never text" }
    },
    "text": {
      "text-100": { "$value": "#000000", "$type": "color", "$description": "H1-H2 headings — text only, never background" },
      "text-70":  { "$value": "#4D4D4D", "$type": "color", "$description": "body and secondary text — text only, never background" },
      "grey-light": { "$value": "#CACBD3", "$type": "color", "$description": "light logo variant, disabled — not a background" }
    },
    "accent": {
      "amber":      { "$value": "#D69043", "$type": "color", "$description": "the ONLY accent: prices, icons, links, active, big numbers on light bg" },
      "amber-soft": { "$value": "#E8B074", "$type": "color", "$description": "hover, secondary accent" },
      "amber-deep": { "$value": "#B87530", "$type": "color", "$description": "pressed state" }
    },
    "border": {
      "line": { "$value": "#E2DDD0", "$type": "color", "$description": "borders, rules" }
    }
  },
  "font": {
    "heading": { "$value": "Gantari", "$type": "fontFamily", "$description": "H1-H4; fallback DM Sans, Plus Jakarta Sans" },
    "body":    { "$value": "Inter",   "$type": "fontFamily", "$description": "body, UI, prices" }
  },
  "typography": {
    "h1":        { "fontFamily": "Gantari", "fontWeight": 700, "letterSpacing": "-0.02em", "lineHeight": 1.1,  "color": "{color.text.text-100}" },
    "h2":        { "fontFamily": "Gantari", "fontWeight": 600, "letterSpacing": "-0.02em", "lineHeight": 1.15, "color": "{color.text.text-100}" },
    "body":      { "fontFamily": "Inter",   "fontWeight": 400, "letterSpacing": "0",       "lineHeight": 1.65, "color": "{color.text.text-70}" },
    "secondary": { "fontFamily": "Inter",   "fontWeight": 500, "letterSpacing": "0.02em",  "lineHeight": 1.5,  "color": "{color.text.text-70}" },
    "price-kpi": { "fontFamily": "Inter",   "fontWeight": 700, "color": "{color.accent.amber}", "$description": "big numbers: Amber on light bg, Cream on dark/amber bg" }
  },
  "radius": {
    "button": { "$value": "12px", "$type": "dimension" },
    "card":   { "$value": "24px", "$type": "dimension" },
    "circle": { "$value": "50%",  "$type": "dimension" }
  },
  "shadow": {
    "card": { "$value": "0 8px 32px rgba(45,49,66,0.08)", "$type": "shadow" }
  },
  "spacing": {
    "web": {
      "container-max": { "$value": "1280px" },
      "container-padding": { "$value": "24px mobile / 40px tablet+" },
      "section-vertical": { "$value": "64px mobile / 80px tablet / 96px desktop" },
      "card-gutter": { "$value": "16px mobile / 24px desktop" },
      "card-padding": { "$value": "28-36px" }
    }
  },
  "rules": [
    "Brand name always written EMAi (uppercase EMA, lowercase i)",
    "Amber is the only accent color — never blue/green/red",
    "Black colors (text-100, text-70) are text-only, never backgrounds; dark surfaces use surface-dark",
    "Big numbers (KPIs, sums, section numbers): Amber on light backgrounds, Cream on dark/amber backgrounds",
    "Max 4 text levels per layout",
    "Icons: bold rounded outline, stroke ~7% of icon size (min 2px), round caps/joins",
    "Logo on grey (surface-dark): use light variant; black/white logo versions only on explicit request",
    "Photos: warm natural light, real seniors/families; overlay rgba(0,0,0,0.30) for text over photo"
  ]
}
